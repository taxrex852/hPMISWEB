    </compilation>
    <pages controlRenderingCompatibilityVersion="4.0"/>
    <!--<httpRuntime maxRequestLength="10240"/>-->
  <httpHandlers><add verb="GET" path="CrystalImageHandler.aspx" type="CrystalDecisions.Web.CrystalImageHandler, CrystalDecisions.Web, Version=13.0.4000.0, Culture=neutral, PublicKeyToken=692fbea5521e1304"/></httpHandlers></system.web>
  <connectionStrings>
    <add name="Y6P2_MaterialsConnectionString" connectionString="Data Source=10.108.20.4;Initial Catalog=Y6P2_Materials;Persist Security Info=True;User ID=sa;Password=Y6P2!@#" providerName="System.Data.SqlClient"/>
    <!--<add name="Y6P2_MaterialsConnectionString" connectionString="Data Source=10.108.137.235;Initial Catalog=Y6P2_Materials_test;Persist Security Info=True;User ID=sa;Password=spcmgr" providerName="System.Data.SqlClient" />-->
